{
    "name": "fast-csv",
    "private": true,
    "scripts": {
        "clean": "lerna run clean",
        "build": "lerna run build",
        "lerna:pub": "lerna publish from-git",
        "lerna:version": "lerna version",
        "release": "pnpm run build && pnpm run lerna:version && pnpm run lerna:pub",
        "test": "pnpm run lint && pnpm run jest && pnpm run examples",
        "format": "prettier --write \"**/*.{ts,js,json,md,mdx,css}\" --ignore-path .prettierignore",
        "format:check": "prettier --check \"**/*.{ts,js,json,md,mdx,css}\" --ignore-path .prettierignore",
        "lint": "eslint --max-warnings 0 \"**/*.ts\" \"examples/**/examples/**/*.js\"",
        "lint:fix": "eslint --max-warnings 0 \"**/*.ts\" \"examples/**/examples/**/*.js\" --fix",
        "lint:ts": "eslint --max-warnings 0 \"**/*.ts\"",
        "lint:js": "eslint --max-warnings 0 \"examples/**/examples/**/*.js\"",
        "jest": "jest --runInBand --coverage",
        "examples": "pnpm -r --if-present run all-examples",
        "benchmarks": "pnpm -r --if-present run benchmarks"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com:C2FO/fast-csv.git"
    },
    "workspaces": [
        "packages/*",
        "examples/*",
        "documentation"
    ],
    "packageManager": "pnpm@10.34.4",
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=10.34.4"
    },
    "devDependencies": {
        "@commitlint/cli": "21.2.0",
        "@commitlint/config-angular": "21.2.0",
        "@eslint/js": "^9.39.2",
        "@types/jest": "30.0.0",
        "@types/node": "24.12.3",
        "@typescript-eslint/eslint-plugin": "8.63.0",
        "@typescript-eslint/parser": "8.63.0",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-jest": "29.15.4",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-tsdoc": "0.5.2",
        "globals": "^17.7.0",
        "husky": "9.1.7",
        "jest": "30.4.2",
        "lerna": "9.0.7",
        "prettier": "3.9.4",
        "ts-jest": "29.4.11",
        "typescript": "5.9.3",
        "typescript-eslint": "^8.63.0"
    },
    "pnpm": {
        "overrides": {
            "@babel/core": "7.29.7",
            "@nx/devkit": "22.7.6",
            "@sigstore/core": "3.2.1",
            "form-data": "4.0.6",
            "http-proxy-middleware": "2.0.10",
            "joi": "18.2.1",
            "js-yaml@^3.13.1": "3.15.0",
            "js-yaml@^4.1.0": "4.3.0",
            "launch-editor": "2.14.1",
            "nx": "22.7.6",
            "qs": "6.15.2",
            "serialize-javascript": "7.0.5",
            "shell-quote": "1.8.4",
            "sigstore": "4.1.1",
            "tar": "7.5.16",
            "tmp": "0.2.7",
            "undici": "6.27.0",
            "uuid": "11.1.1",
            "webpack-dev-server": "5.2.5",
            "ws@^7.0.0": "7.5.11",
            "ws@^8.0.0": "8.21.0"
        }
    }
}
